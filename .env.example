# H1BHunter Environment Configuration
# Copy this file to .env and fill in your values
# For Railway: Set these in Railway dashboard → Variables

# Server
NODE_ENV=production
PORT=3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-strong
JWT_EXPIRES_IN=7d

# Database (Railway will handle persistence automatically)
DB_PATH=./data/h1bhunter.db

# Email (Gmail SMTP - completely free)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
# Get EMAIL_PASS from: Google Account → Security → App Passwords

# Stripe Payment (free tier available)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PRICE_ID=price_your_h1bhunter_premium_monthly_price_id
# Create product at stripe.com → Products → Add Product
# Name: H1BHunter Premium
# Price: $9.00/month (recurring)

# Company Data Cache
CACHE_DIR=./data/company-cache

# Logging
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10M
LOG_MAX_FILES=5

# Creator Monitoring (optional)
SEND_USAGE_TO_CREATOR=true
CREATOR_WALLET_ADDRESS=shafkat-khan
CREDIT_BALANCE=100

# CORS Configuration (Railway auto-domain)
ALLOWED_ORIGINS=http://localhost:3000,https://*.railway.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_PREMIUM=true
ENABLE_OPTGUARD=true
ENABLE_EMAIL_ALERTS=true
ENABLE_JOB_SCRAPING=true
